<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColor">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add New Service"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/textColorPrimary"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp" />

        <!-- Service Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Service Name"
            android:textSize="14sp"
            android:textColor="@color/textColorSecondary" />

        <EditText
            android:id="@+id/etServiceName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. Deep Home Cleaning"
            android:inputType="textCapSentences"
            android:layout_marginBottom="16dp"
            android:layout_marginTop="4dp" />

        <!-- Category -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Category"
            android:textSize="14sp"
            android:textColor="@color/textColorSecondary" />

        <!-- Spinner for category selection -->
        <Spinner
            android:id="@+id/spinnerCategory"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="16dp"
            android:layout_marginTop="4dp" />

        <!-- Description -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Description"
            android:textSize="14sp"
            android:textColor="@color/textColorSecondary" />

        <EditText
            android:id="@+id/etDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Describe the service"
            android:inputType="textMultiLine"
            android:lines="3"
            android:gravity="top"
            android:layout_marginBottom="16dp"
            android:layout_marginTop="4dp" />

        <!-- Price -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Price (Rs.)"
            android:textSize="14sp"
            android:textColor="@color/textColorSecondary" />

        <EditText
            android:id="@+id/etPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. 2500"
            android:inputType="numberDecimal"
            android:layout_marginBottom="16dp"
            android:layout_marginTop="4dp" />

        <!-- Provider Phone -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Provider Phone"
            android:textSize="14sp"
            android:textColor="@color/textColorSecondary" />

        <EditText
            android:id="@+id/etProviderPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="+94 77 000 0000"
            android:inputType="phone"
            android:layout_marginBottom="32dp"
            android:layout_marginTop="4dp" />

        <!-- Location section for Google Maps -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Location (for Google Maps)"
            android:textSize="14sp"
            android:textColor="@color/textColorSecondary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Leave empty to use default (Colombo)"
            android:textSize="12sp"
            android:textColor="#9E9E9E"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etLatitude"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Latitude (e.g. 6.9271)"
            android:inputType="numberDecimal|numberSigned"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etLongitude"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Longitude (e.g. 79.8612)"
            android:inputType="numberDecimal|numberSigned"
            android:layout_marginBottom="32dp" />

        <!-- Loading -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="8dp" />

        <!-- Save Service Button -->
        <Button
            android:id="@+id/btnSaveService"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Save Service"
            android:textAllCaps="false"
            android:textSize="17sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

    </LinearLayout>
</ScrollView>
