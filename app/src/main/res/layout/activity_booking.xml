<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/backgroundColor">

    <!-- Gradient Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/gradient_header"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="44dp"
        android:paddingBottom="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Book Service"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvBookingServiceName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Service Name"
            android:textColor="#B3E5FC"
            android:textSize="15sp" />
    </LinearLayout>

    <!-- Form Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="-16dp"
        android:background="@drawable/rounded_top_white"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="40dp">

            <!-- ── Service Image Card ── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardServiceImage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <ImageView
                    android:id="@+id/imgServicePreview"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:scaleType="centerCrop"
                    android:contentDescription="Service Image" />

            </com.google.android.material.card.MaterialCardView>

            <!-- ── Your Address Section ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="YOUR SERVICE ADDRESS"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/textColorSecondary"
                android:letterSpacing="0.1"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Where do you need this service?"
                android:textSize="12sp"
                android:textColor="@color/textColorHint"
                android:layout_marginBottom="12dp" />

            <!-- Address Search Button -->
            <TextView
                android:id="@+id/btnPickAddress"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_outlined_card"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="Search Your Address"
                android:textColor="@color/primaryColor"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <!-- Selected address card (hidden until a place is picked) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#F0F4FF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_compass"
                        app:tint="@color/primaryColor"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:id="@+id/tvSelectedAddress"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text=""
                        android:textColor="@color/textColorPrimary"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Date Section ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SELECT DATE"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/textColorSecondary"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <Button
                    android:id="@+id/btnSelectDate"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@null"
                    android:text="Tap to Pick a Date"
                    android:textAllCaps="false"
                    android:textSize="15sp"
                    android:textColor="@color/textColorPrimary"
                    android:gravity="start|center_vertical"
                    android:paddingStart="16dp" />
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Time Section ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SELECT TIME"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/textColorSecondary"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="40dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <Button
                    android:id="@+id/btnSelectTime"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@null"
                    android:text="Tap to Pick a Time"
                    android:textAllCaps="false"
                    android:textSize="15sp"
                    android:textColor="@color/textColorPrimary"
                    android:gravity="start|center_vertical"
                    android:paddingStart="16dp" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Progress -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone"
                android:layout_marginBottom="8dp" />

            <!-- Confirm Button -->
            <Button
                android:id="@+id/btnConfirmBooking"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/btn_primary"
                android:text="Confirm Booking"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
