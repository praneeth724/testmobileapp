<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Internet access (required for Firebase and Google Maps) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- For Call Provider button -->
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <!-- For push notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- For picking images from gallery (Android 13+) -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.HomeServiceGo">

        <!--
            Google Maps API Key
            IMPORTANT: Replace YOUR_MAPS_API_KEY_HERE with your actual key.
            Steps to get a key:
            1. Go to https://console.cloud.google.com
            2. Create a project → Enable "Maps SDK for Android"
            3. Go to Credentials → Create API Key
            4. Paste the key below
        -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="AIzaSyDl-ZKttCbeZYQxn50OrIP71CTK14HRMpk" />

        <!-- ===== SPLASH / AUTH ===== -->
        <activity
            android:name=".activities.SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".activities.LoginActivity" />
        <activity android:name=".activities.RegisterActivity" />

        <!-- ===== CUSTOMER SCREENS ===== -->
        <activity android:name=".activities.HomeActivity" />
        <activity android:name=".activities.ServiceListActivity" android:exported="false" />
        <activity android:name=".activities.ServiceDetailActivity" />
        <activity android:name=".activities.BookingActivity" />
        <activity android:name=".activities.BookingHistoryActivity" />
        <activity android:name=".activities.ProfileActivity" />
        <activity android:name=".activities.MapActivity" />

        <!-- ===== ADMIN SCREENS ===== -->
        <activity android:name=".activities.AdminActivity" />
        <activity android:name=".activities.AdminBookingsActivity" />
        <activity android:name=".activities.AdminManageServicesActivity" />
        <activity android:name=".activities.AdminAddServiceActivity" />
        <activity android:name=".activities.AdminEditServiceActivity" />

        <!-- ===== LEGACY ===== -->
        <activity android:name=".MainActivity" android:exported="true" />

        <!-- ===== FIREBASE CLOUD MESSAGING ===== -->
        <service
            android:name=".notifications.MyFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

    </application>

</manifest>
